[Unit]
Description=Local Camera Server
After=network.target

[Service]
ExecStart=/home/user/chimera-deploy/local/local_start_camera_server.sh
WorkingDirectory=/home/user/chimera-deploy/local
User=user
Group=user
Restart=always
RestartSec=5
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target
